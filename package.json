{
  "name": "mailstracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev dist --port 8788 --local",
    "dev:all": "mkdir -p dist && concurrently -n \"vite,worker\" -c \"cyan,yellow\" \"vite\" \"wrangler pages dev dist --port 8788 --local\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "db:init": "wrangler d1 execute mailstracker-db --local --file=./schema.sql",
    "setup": "npm install && mkdir -p dist && npm run db:init && echo '✅ Ready! Run: npm run dev:all'"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.3.5",
    "wrangler": "^4.110.0"
  }
}
